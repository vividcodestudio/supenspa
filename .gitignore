# Clean Root Philosophy - Ignoring all non-essential root files

# Environment & Dependencies
Config/node_modules/
Config/.vscode/
Config/.openmcp/

# System Files
.DS_Store
Thumbs.db

# Logs & Temp
*.log
Config/server.log
tmp/
temp/

# IDEs
.idea/
.project
.settings/
.vscode/

# Project Specific
website/assets/css/*.map

# Large Media Files (exceed GitHub 100MB limit)
*.mp4
*.mov
*.avi
*.mkv
*.zip
*.tar
*.tar.gz
*.rar
*.7z

# Legacy asset folder with heavy originals
website/assets/Supen-Spa\ Assets/
website/assets/images/Supen-Spa.zip
website/assets/images/Supen\ Video-*.mp4
website/assets/images/Thai-Spa-Message-Video.mp4

# Clean Root Enforcement - Proactively ignore misplaced files in root
# (Forces developers to move them to Config/)
/*.log
/*.json
/*.config
/*.lock
/*.yaml
/*.yml
/*.xml
